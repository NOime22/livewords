/* pages/settings/index.wxss */
.settings-container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: var(--bg-body);
  background-image: radial-gradient(var(--border-color) 2rpx, transparent 2rpx);
  background-size: 40rpx 40rpx;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: transparent;
}

.header-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  background: transparent;
}

.header-back,
.header-spacer {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.header-back-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #111;
}

.header-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.auth-card {
  margin-bottom: 32rpx;
  padding: 28rpx;
  background: #fff;
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.auth-title {
  font-size: 30rpx;
  font-weight: 900;
  text-transform: uppercase;
}

.auth-desc {
  margin: 12rpx 0 20rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.auth-error {
  margin-top: 16rpx;
  font-weight: 700;
  color: #D63031;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
  padding: 24rpx;
  background: #fff;
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-card);
  border-radius: var(--radius-md);
  transform: rotate(-1deg);
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 140rpx;
}

.avatar-btn {
  width: 128rpx !important;
  height: 128rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: none !important;
  border-radius: 50% !important;
  overflow: hidden;
  line-height: 1 !important;
}
.avatar-btn::after {
  display: none !important;
}

.avatar-lg {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid var(--border-color);
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.avatar-hint {
  font-size: 20rpx;
  color: #888;
  margin-top: 8rpx;
}

.nickname-input {
  border: none;
  background: transparent;
  font-weight: 900;
  font-size: 40rpx;
  line-height: 52rpx;
  height: 56rpx;
  padding: 0 0 4rpx;
  margin: 0;
  width: 100%;
  color: #111;
  box-sizing: border-box;
}
.nickname-input::placeholder {
  color: #aaa;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.text-h2 {
  font-weight: 900;
  text-transform: uppercase;
  font-size: 40rpx;
}

.stats-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-badge {
  background: var(--primary); /* Yellow */
  padding: 8rpx 20rpx;
  border: 4rpx solid var(--border-color);
  border-radius: 999rpx;
  display: flex;
  gap: 8rpx;
  align-items: center;
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.stat-val { font-weight: 900; color: var(--text-main); font-size: 28rpx; }
.stat-lbl { font-size: 24rpx; color: var(--text-main); font-weight: 600; text-transform: uppercase; }

.setting-item {
  margin-bottom: 32rpx;
}

.setting-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.label-main { font-weight: 800; font-size: 28rpx; text-transform: uppercase; }

.label-value {
  font-weight: 900;
  font-size: 28rpx;
  color: var(--success);
  background: #000;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.label-sub {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 2rpx solid;
  margin-left: 12rpx;
}

.slider-range {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.model-pill {
  padding: 14rpx 20rpx;
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  background: #fff;
  font-weight: 700;
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.order-tabs {
  display: flex;
  gap: 16rpx;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border: 4rpx solid var(--border-color);
  background: #fff;
  font-weight: 700;
  border-radius: var(--radius-sm);
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.order-tab.active {
  background: var(--success);
  color: var(--text-main);
  box-shadow: none;
  transform: translate(4rpx, 4rpx);
}

.letter-picker {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.letter-label {
  font-weight: 700;
  font-size: 24rpx;
}

.letter-pill {
  padding: 8rpx 32rpx;
  border: 4rpx solid var(--border-color);
  border-radius: 999rpx;
  background: var(--success);
  color: var(--text-main);
  font-weight: 900;
  text-transform: uppercase;
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}



.deck-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border: 4rpx solid var(--border-color);
  background: #fff;
  margin-bottom: 16rpx;
  transition: all 0.2s;
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.deck-option.active {
  background: var(--accent); /* Blue */
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.deck-title { font-weight: 900; font-size: 28rpx; display: block; }
.deck-tags { font-size: 22rpx; color: var(--text-main); margin-top: 4rpx; display: block; font-weight: 600; }

.footer-area {
  margin-top: 64rpx;
  padding: 32rpx;
}

.eval-dev-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 4rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  background: #eff6ff;
}

/* 危险操作区域样式 */
/* 危险操作区域样式 */
.danger-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
  font-weight: 500;
  line-height: 1.4;
}

.danger-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.danger-badge {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border: 2rpx solid #ff8a80;
  border-radius: 12rpx;
  color: #ff5a5f;
  background: #fff5f5;
  font-size: 22rpx;
  font-weight: 800;
}

.danger-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 24rpx;
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-md);
  background: #fff;
  box-shadow: 4rpx 4rpx 0 var(--border-color);
}

.danger-action-text {
  color: #ff4d4f;
  font-size: 30rpx;
  font-weight: 900;
}

.mb-0 {
  margin-bottom: 0 !important;
}
