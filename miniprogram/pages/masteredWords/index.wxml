<view class="page mastered-page">
  <view class="page-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-bar">
      <view class="header-back" bindtap="onBack">
        <text class="header-back-icon">‹</text>
      </view>
      <text class="header-title">已掌握单词</text>
      <view class="header-spacer"></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="mastered-state">
    <view class="spinner-retro"></view>
    <text class="state-text">加载已掌握单词...</text>
  </view>

  <view wx:elif="{{error}}" class="mastered-state">
    <text class="state-icon">📭</text>
    <text class="state-text">{{error}}</text>
    <view class="retry-btn" bindtap="loadWords">重试</view>
  </view>

  <scroll-view
    wx:elif="{{words.length > 0}}"
    class="mastered-scroll"
    scroll-y
    style="padding-top: calc(88rpx + {{statusBarHeight}}px + 12rpx);"
  >
    <view class="mastered-content">
      <view class="mastered-summary">
        <view class="summary-copy">
          <text class="summary-title">完全掌握</text>
          <text class="summary-subtitle">点击卡片展开释义</text>
        </view>
        <view class="summary-badge">
          <text class="summary-badge-value">{{total}}</text>
          <text class="summary-badge-label">个单词</text>
        </view>
      </view>

      <view class="mastered-stack">
        <view
          wx:for="{{displayWords}}"
          wx:key="word"
          class="word-card {{item.isActive ? 'is-active' : ''}} {{item.isAfterActive ? 'is-after-active' : ''}} {{item.isBeforeActive ? 'is-before-active' : ''}}"
          data-index="{{item.cardIndex}}"
          bindtap="toggleWordCard"
          style="z-index: {{item.zIndex}};"
        >
          <view class="word-row-main">
            <text class="word-text">{{item.word}}</text>
            <text wx:if="{{item.isActive && item.phonetic}}" class="word-phonetic">/{{item.phonetic}}/</text>
          </view>

          <view class="word-card-body {{item.isActive ? 'is-visible' : ''}}">
            <text wx:if="{{item.pos || item.translation || item.definition}}" class="word-definition">
              {{item.pos ? item.pos + ' ' : ''}}{{item.translation || item.definition}}
            </text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:else class="mastered-state">
    <text class="state-icon">📝</text>
    <text class="state-text">还没有完全掌握的单词</text>
  </view>
</view>
